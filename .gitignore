# Ignore the heavy reference images
reference_images/

# Source input images (trademark/personal art precedent — never committed)
input_images/

# Ignore generated inspection renders (regenerated each run)
renders/

# Ignore Linux/system hidden files
.DS_Store
*~

# Python
__pycache__/
*.pyc

# E2E corpus-run evidence hygiene: keep JSON/SVG/preview evidence, exclude
# regenerable uncompressed BMPs and per-job artwork copies (duplicates of
# committed corpus artifacts; originals policy: never commit source art).
reports/e2e/pass_*/stitch/*.bmp
jobs/*/artwork/
# Working SVGs embed the source raster (8+ MB each) and are regenerable from
# the committed production SVG + input image; the reviewed artifact is
# *_production.svg (ORGANIZATION_BASIS.md cleanup decision).
reports/e2e/pass_*/*_work.svg
